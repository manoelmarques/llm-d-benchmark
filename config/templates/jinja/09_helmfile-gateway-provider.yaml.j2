{#
  Gateway provider helmfile -- rendered for modelservice deployments that
  install their own gateway control plane. Currently handles:

    - istio     (istio-base + istiod from the istio helm repo)
    - agentgateway  (agentgateway-crds + agentgateway from the upstream OCI registry)

  Other providers (gke, data-science-gateway-class) are platform-managed
  and emit an empty helmfile here -- the step consumer treats an empty
  rendered file as "nothing to install" via _has_yaml_content().

  The agentgateway release layout mirrors the canonical upstream helmfile:
    https://raw.githubusercontent.com/llm-d-incubation/llm-d-infra/refs/heads/main/quickstart/gateway-control-plane-providers/agentgateway.helmfile.yaml
#}
{% set gw_class = gateway.className %}
{% set gw_ns = gateway.providerNamespace %}
{% if standalone.enabled is defined and not standalone.enabled and gw_class == 'istio' %}
repositories:
  - name: istio
    url: {{ helmRepositories.istio.url }}

releases:
  - name: istio-base
    chart: istio/base
    version: {{ chartVersions.istioBase }}
    namespace: {{ gw_ns }}
    createNamespace: true
    installed: true
    labels:
      type: gateway-provider
      kind: gateway-crds

  - name: istiod
    chart: istio/istiod
    version: {{ chartVersions.istiod }}
    namespace: {{ gw_ns }}
    createNamespace: true
    installed: true
    needs:
      - {{ gw_ns }}/istio-base
    values:
      - meshConfig:
          defaultConfig:
            proxyMetadata:
              ENABLE_GATEWAY_API_INFERENCE_EXTENSION: true
        pilot:
          env:
            ENABLE_GATEWAY_API_INFERENCE_EXTENSION: true
        tag: {{ chartVersions.istiod }}
        hub: "docker.io/istio"
    labels:
      type: gateway-provider
      kind: gateway-control-plane
{% elif standalone.enabled is defined and not standalone.enabled and gw_class == 'agentgateway' %}
{% set agw = gatewayProviders.agentgateway %}
{% set agw_ns = agw.namespace %}
{% set agw_repo = agw.helmRepository.rstrip('/') %}
{% set agw_version = chartVersions.agentgateway %}
releases:
  - name: agentgateway-crds
    chart: {{ agw_repo }}/agentgateway-crds
    namespace: {{ agw_ns }}
    createNamespace: true
    version: {{ agw_version }}
    installed: true
    labels:
      type: gateway-provider
      kind: gateway-crds

  - name: agentgateway
    chart: {{ agw_repo }}/agentgateway
    version: {{ agw_version }}
    namespace: {{ agw_ns }}
    createNamespace: true
    installed: true
    needs:
      - {{ agw_ns }}/agentgateway-crds
    values:
      - inferenceExtension:
          enabled: true
        securityContext:
          allowPrivilegeEscalation: false
          capabilities:
            drop: ["ALL"]
        podSecurityContext:
          seccompProfile:
            type: "RuntimeDefault"
          runAsNonRoot: true
{% if gateway.resources is defined and gateway.resources %}
        resources:
{{ gateway.resources | toyaml | indent(10, true) }}
{% endif %}
    labels:
      type: gateway-provider
      kind: gateway-control-plane
{% endif %}
