# Sim Example Specification
# Simulated inference deployment using llm-d-inference-sim. No GPUs required.
# See scenarios/examples/sim.yaml for details.

# [REQUIRED]
{% set base_dir = base_dir | default('../') -%}
base_dir: {{ base_dir }}

# [REQUIRED]
values_file:
  path: {{ base_dir }}/config/templates/values/defaults.yaml

# [REQUIRED]
template_dir:
  path: {{ base_dir }}/config/templates/jinja

# [OPTIONAL]
scenario_file:
  path: {{ base_dir }}/config/scenarios/examples/sim.yaml
