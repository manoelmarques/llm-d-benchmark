# Kind Simulated Accelerators CI/CD Specification
# CI/CD scenario for Kind clusters using inference simulation (no GPU).
# See scenarios/cicd/kind-sim.yaml for details.

# [REQUIRED]
{% set base_dir = base_dir | default('../') -%}
base_dir: {{ base_dir }}

# [REQUIRED]
values_file:
  path: {{ base_dir }}/config/templates/values/defaults.yaml

# [REQUIRED]
template_dir:
  path: {{ base_dir }}/config/templates/jinja

# [OPTIONAL]
scenario_file:
  path: {{ base_dir }}/config/scenarios/cicd/kind-sim.yaml
