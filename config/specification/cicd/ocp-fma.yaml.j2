# OpenShift Container Platform CI/CD Specification - FMA
# FMA variant of cicd/ocp — uses nop harness.
# See scenarios/cicd/ocp-fma.yaml for details.

# [REQUIRED]
{% set base_dir = base_dir | default('../') -%}
base_dir: {{ base_dir }}

# [REQUIRED]
values_file:
  path: {{ base_dir }}/config/templates/values/defaults.yaml

# [REQUIRED]
template_dir:
  path: {{ base_dir }}/config/templates/jinja

# [OPTIONAL]
scenario_file:
  path: {{ base_dir }}/config/scenarios/cicd/ocp-fma.yaml
