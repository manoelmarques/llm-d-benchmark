# GKE H100 CI/CD Specification
# CI/CD scenario for Google Kubernetes Engine clusters with H100 GPUs.
# See scenarios/cicd/gke-h100.yaml for details.

# [REQUIRED]
{% set base_dir = base_dir | default('../') -%}
base_dir: {{ base_dir }}

# [REQUIRED]
values_file:
  path: {{ base_dir }}/config/templates/values/defaults.yaml

# [REQUIRED]
template_dir:
  path: {{ base_dir }}/config/templates/jinja

# [OPTIONAL]
scenario_file:
  path: {{ base_dir }}/config/scenarios/cicd/gke-h100.yaml
